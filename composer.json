{
  "name": "edin/lexicon-syntax",
  "description": "BNF-style grammar parser, validator, and code generator for Lexicon-powered syntax tools.",
  "type": "library",
  "keywords": [
    "grammar",
    "bnf",
    "ebnf",
    "lexer",
    "parser",
    "ast",
    "syntax",
    "validator",
    "code-generator",
    "linter",
    "lexicon"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "Edin Omeragic",
      "role": "Author"
    },
    {
      "name": "Codex",
      "role": "Contributor"
    }
  ],
  "autoload": {
    "psr-4": {
      "LexiconSyntax\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LexiconSyntax\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/lsyn"
  ],
  "require": {
    "php": "^8.2",
    "edin/lexicon": "^0.4"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "analyse": "phpstan analyse --memory-limit=256M",
    "test": "phpunit",
    "test:dox": "phpunit --testdox --colors=always"
  },
  "config": {
    "sort-packages": true
  }
}
