{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lexicon Syntax",
  "scopeName": "source.lexicon-syntax",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#custom-matchers"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.lexicon-syntax",
          "match": "//.*$"
        },
        {
          "name": "comment.block.lexicon-syntax",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.lexicon-syntax",
          "begin": "#\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.attribute.begin.lexicon-syntax"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.attribute.end.lexicon-syntax"
            }
          },
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#operators"
            },
            {
              "name": "entity.name.function.attribute.lexicon-syntax",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lexicon-syntax",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lexicon-syntax",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.lexicon-syntax",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.lexicon-syntax",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.lexicon-syntax",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.token.lexicon-syntax",
          "match": "\\b(token)\\s+(?:(keyword|symbol|literal|trivia|eof|unknown)\\s+)?([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.token.lexicon-syntax"
            },
            "2": {
              "name": "storage.modifier.token-category.lexicon-syntax"
            },
            "3": {
              "name": "entity.name.type.token.lexicon-syntax"
            }
          }
        },
        {
          "name": "meta.declaration.rule.lexicon-syntax",
          "match": "\\b(rule)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.rule.lexicon-syntax"
            },
            "2": {
              "name": "entity.name.function.rule.lexicon-syntax"
            }
          }
        },
        {
          "name": "meta.declaration.type.lexicon-syntax",
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.lexicon-syntax"
            },
            "2": {
              "name": "entity.name.type.alias.lexicon-syntax"
            }
          }
        },
        {
          "name": "meta.declaration.node.lexicon-syntax",
          "match": "\\b(node)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.node.lexicon-syntax"
            },
            "2": {
              "name": "entity.name.class.node.lexicon-syntax"
            }
          }
        },
        {
          "name": "meta.declaration.attribute.lexicon-syntax",
          "match": "\\b(attribute)\\s+(token|rule|grammar|[A-Za-z_][A-Za-z0-9_]*)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.attribute.lexicon-syntax"
            },
            "2": {
              "name": "storage.type.attribute-target.lexicon-syntax"
            },
            "3": {
              "name": "entity.name.function.attribute.lexicon-syntax"
            }
          }
        },
        {
          "name": "meta.import.lexicon-syntax",
          "match": "\\b(import)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.lexicon-syntax"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "constant.language.boolean.lexicon-syntax",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "support.type.builtin.lexicon-syntax",
          "match": "\\b(?:string|number|bool|identifier|token|rule|grammar|enum)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.definition.lexicon-syntax",
          "match": "::=|=>|\\.\\.|="
        },
        {
          "name": "keyword.operator.choice.lexicon-syntax",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.quantifier.lexicon-syntax",
          "match": "[?*+]"
        },
        {
          "name": "punctuation.separator.lexicon-syntax",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.bracket.lexicon-syntax",
          "match": "[()\\[\\]{}]"
        }
      ]
    },
    "custom-matchers": {
      "patterns": [
        {
          "name": "meta.custom-matcher.lexicon-syntax",
          "match": "<([A-Za-z_][A-Za-z0-9_]*)>",
          "captures": {
            "1": {
              "name": "entity.name.type.matcher.lexicon-syntax"
            }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.identifier.lexicon-syntax",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
